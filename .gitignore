# ============================================
# QuizLearn .gitignore
# ============================================

# Dependencies
node_modules/
package-lock.json

# Environment files (keep .env.example)
.env
.env.local
.env.production
.env.*.local

# Build output
dist/
build/
.vercel/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# Temporary files
*.tmp
*.temp
.cache/
.temp/

# Data (for persistent data)
data/

# Test coverage
coverage/
.nyc_output/

# Misc
*.bak
*.backup
*.old
