# ============================================
# QuizLearn Environment Variables
# ============================================

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Groq API (for AI-powered word generation and translation)
# Get from: https://console.groq.com/keys
VITE_GROQ_API_KEY=gsk_your-groq-key-here

# Azure Speech Services (for Text-to-Speech and Pronunciation Assessment)
# Get from: https://portal.azure.com -> Cognitive Services -> Speech Services
VITE_AZURE_SPEECH_REGION=eastus
VITE_AZURE_SPEECH_KEY=your-azure-speech-key-here

# Optional: Server-side only (not exposed to frontend)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
